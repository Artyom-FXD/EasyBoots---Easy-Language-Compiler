{
    "name": "file",
    "version": "1.0.0",
    "language_version": ">=26.5",
    "description": "File system operations — cross-platform file I/O, path utilities, directory listing, and metadata queries. Native C backend compiled to static library.",
    "author": "ElySpruce authors",
    "license": "MIT",
    "stx": {
        "processType": "module",
        "optimization": "hard"
    },
    "output": {
        "libmain": "src/file.ely",
        "native": true,
        "nativeSources": [
            "src/file_native.c"
        ],
        "elyfile": [
            "src/file.ely",
            "LICENSE"
        ]
    },
    "include": [
        "src/file.ely",
        "src/file_native.c",
        "elymodule.json",
        "LICENSE"
    ]
}